# Mako notification config — based on basecamp/omarchy
# Colors injected by theme-switch.sh on theme change

anchor=top-right
default-timeout=5000
width=420
outer-margin=20
padding=10,15
border-size=2
max-icon-size=32
font=sans-serif 14px

# Colors — updated by theme-switch.sh
text-color=#ffffff
border-color=#8d8d8d
background-color=#000000

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[urgency=critical]
default-timeout=0
layer=overlay

[summary~="Screenshot copied & saved"]
max-icon-size=80
format=<b>%s</b>\n%b
