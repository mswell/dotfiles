# copy to ~/
[user]
	name = Wellington Moraes
	email = wellpunk@gmail.com
[push]
	default = simple
[init]
  defaultBranch = main
[credential]
	helper = cache --timeout=86400
[core]
	editor = vim
  pager = delta
  hooksPath = ~/.config/git/hooks

# Global pre-commit scanner defaults. Override per repo with:
#   git config hooks.secretScan false
#   git config hooks.secretScanMode warn
#   git config hooks.genericSecretMode block
[hooks]
  secretScan = true
  secretScanMode = block
  genericSecretMode = warn

[interactive]
  diffFilter = delta --color-only --features=interactive

[delta]
  features = decorations
  side-by-side = true
  line-numbers = true

[include]
  path = ~/.config/git/current-theme.gitconfig

[delta "interactive"]
  keep-plus-minus-markers = false

[merge]
	tool = vimdiff
